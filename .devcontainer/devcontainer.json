// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/docker-existing-dockerfile
// git ssh: https://code.visualstudio.com/remote/advancedcontainers/sharing-git-credentials
{
	"name": "FAsset Indexer Container",
    "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
    "initializeCommand": "mkdir -p ${localEnv:HOME}/.claude && touch ${localEnv:HOME}/.claude.json",
    "postCreateCommand": "npm install -g @anthropic-ai/claude-code",
    "mounts": [
        "source=/dev/null,target=${containerWorkspaceFolder}/.env,type=bind,readonly",
        "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind",
        "source=${localEnv:HOME}/.claude.json,target=/home/node/.claude.json,type=bind"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "mikestead.dotenv",
                "esbenp.prettier-vscode",
                "dbaeumer.vscode-eslint",
                "eamodio.gitlens",
                "usernamehw.errorlens",
                "ms-azuretools.vscode-docker",
                "christian-kohler.path-intellisense",
                "wayou.vscode-todo-highlight",
                "pkief.material-icon-theme",
                "anthropic.claude-code"
            ],
            "settings": {
                "[typescript]": {
                    "editor.defaultFormatter": "vscode.typescript-language-features",
                    "editor.tabSize": 2
                },
                "editor.insertSpaces": true,
                "editor.detectIndentation": false,
                "files.trimFinalNewlines": true,
                "files.trimTrailingWhitespace": true
            }
        }
    }
}
